{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for AirAssistant overlay and trigger windows",
  "windows": ["overlay", "trigger"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:event:default",
    "dialog:default",
    "autostart:default",
    "opener:default"
  ]
}
